.TH "KUBECONFIG-MANAGER" "1" "Jan 0001" "kubeconfig-manager" ""

.SH NAME
kcm-alert-enable - Enable alerts for a kubeconfig (populates default blocked verbs)


.SH SYNOPSIS
\fBkcm alert enable  [flags]\fP


.SH DESCRIPTION
Enable alerts for a kubeconfig (populates default blocked verbs)


.SH OPTIONS
\fB--dir\fP=""
	Kubeconfig directory (default: ~/.kube)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for enable


.SH SEE ALSO
\fBkcm-alert(1)\fP
