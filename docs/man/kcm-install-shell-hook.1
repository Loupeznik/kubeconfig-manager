.nh
.TH "KUBECONFIG-MANAGER" "1" "Jan 0001" "kubeconfig-manager" ""

.SH NAME
kcm-install-shell-hook - Install shell integration (kcm function, optional kubectl alias)


.SH SYNOPSIS
\fBkcm install-shell-hook [flags]\fP


.SH DESCRIPTION
Install shell integration (kcm function, optional kubectl alias)


.SH OPTIONS
\fB--alias-kubectl\fP[=false]
	Also alias kubectl to route through the guard (opt-in)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for install-shell-hook

.PP
\fB--rc\fP=""
	rc file path (default depends on shell)

.PP
\fB--shell\fP=""
	bash, zsh, or pwsh (auto-detected if unset)


.SH SEE ALSO
\fBkcm(1)\fP
