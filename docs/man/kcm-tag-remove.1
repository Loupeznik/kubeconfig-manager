.SH NAME
kcm-tag-remove - Remove tags from a kubeconfig


.SH SYNOPSIS
\fBkcm tag remove   [flags]\fP


.SH DESCRIPTION
Remove tags from a kubeconfig


.SH OPTIONS
\fB--dir\fP=""
	Kubeconfig directory (default: ~/.kube)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for remove


.SH SEE ALSO
\fBkcm-tag(1)\fP
