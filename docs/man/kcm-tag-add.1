.TH "KUBECONFIG-MANAGER" "1" "Jan 0001" "kubeconfig-manager" ""

.SH NAME
kcm-tag-add - Add tags (file-level, or --context for one context only)


.SH SYNOPSIS
\fBkcm tag add   [flags]\fP


.SH DESCRIPTION
Add tags (file-level, or --context for one context only)


.SH OPTIONS
\fB--allow-new\fP[=false]
	Add tags to the palette automatically if not present

.PP
\fB--context\fP=""
	Apply to this context only (default: file-level)

.PP
\fB--dir\fP=""
	Kubeconfig directory (default: ~/.kube)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for add


.SH SEE ALSO
\fBkcm-tag(1)\fP
