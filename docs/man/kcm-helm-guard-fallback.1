.TH "KUBECONFIG-MANAGER" "1" "Jan 0001" "kubeconfig-manager" ""

.SH NAME
kcm-helm-guard-fallback - Toggle the pattern-less global fallback (compare path tokens directly when no pattern matches)


.SH SYNOPSIS
\fBkcm helm-guard fallback  [flags]\fP


.SH DESCRIPTION
Toggle the pattern-less global fallback (compare path tokens directly when no pattern matches)


.SH OPTIONS
\fB--dir\fP=""
	Kubeconfig directory (default: ~/.kube)

.PP
\fB--file\fP=""
	Apply only to this kubeconfig (default: global)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for fallback


.SH SEE ALSO
\fBkcm-helm-guard(1)\fP
